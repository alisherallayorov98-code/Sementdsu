# ─────────────────────────────────────────────────────────────────────────────
# SEMENT — Nginx reverse-proxy + HTTPS namunasi (internetga chiqarish uchun).
# Bu faylni serverdagi nginx'ga moslang:
#   /etc/nginx/sites-available/sement  → sites-enabled'ga symlink
# SSL sertifikat: Let's Encrypt (bepul) — certbot bilan oling.
# ─────────────────────────────────────────────────────────────────────────────

# HTTP → HTTPS yo'naltirish
server {
    listen 80;
    server_name sement.example.uz www.sement.example.uz;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name sement.example.uz www.sement.example.uz;

    # ── SSL (Let's Encrypt) ──────────────────────────────────────────────────
    # sudo certbot --nginx -d sement.example.uz -d www.sement.example.uz
    ssl_certificate     /etc/letsencrypt/live/sement.example.uz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/sement.example.uz/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    # Xavfsizlik sarlavhalari
    add_header Strict-Transport-Security "max-age=31536000" always;
    client_max_body_size 25m;

    # ── Frontend (statik build) ──────────────────────────────────────────────
    # MUHIM: deploy.sh build'ni shu papkaga ko'chiradi (dashboard/dist EMAS!).
    root /var/www/sement;
    index index.html;
    location / {
        try_files $uri $uri/ /index.html;   # SPA — barcha yo'llar index.html'ga
    }

    # index.html'ni KESHLAMASLIK — har deploy'dan keyin yangi build darhol ko'rinadi.
    # (Hash'li assets/*.js, *.css esa abadiy keshlanadi — ular nomi o'zgaradi.)
    location = /index.html {
        add_header Cache-Control "no-store, must-revalidate";
        expires 0;
    }

    # ── Backend API (Node, 5000-portda) ──────────────────────────────────────
    location /api/ {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
