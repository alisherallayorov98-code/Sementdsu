# ─────────────────────────────────────────────────────────────────────────────
# SEMENT backend sozlamalari. Bu faylni "backend/.env" nomi bilan nusxalang:
#   cp backend/.env.example backend/.env
# .env GIT'ga TUSHMAYDI (maxfiy).
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────
PORT=5000
# development | production  (production'da xato tafsilotlari yashiriladi)
NODE_ENV=production

# ── Xavfsizlik ────────────────────────────────────────────────────────────
# JWT siri. Bo'sh qoldirsangiz — avtomatik yaratiladi (data/.jwt_secret).
# Internetga chiqarganda KUCHLI tasodifiy qiymat qo'ying (kamida 32 belgi):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
# Token amal qilish muddati (masalan: 12h, 7d)
JWT_EXPIRES=12h

# Ruxsat etilgan frontend manzillari (vergul bilan). '*' — barchasi (faqat LAN/lokal).
# Internet misol: CORS_ORIGINS=https://sement.example.uz,https://www.sement.example.uz
CORS_ORIGINS=*

# ── Telegram bot ──────────────────────────────────────────────────────────
# @BotFather'dan olingan token. Bo'sh bo'lsa bot ishlamaydi (qolgan qism ishlaydi).
TELEGRAM_BOT_TOKEN=

# ── SMS (Eskiz.uz) ────────────────────────────────────────────────────────
# Eskiz hisobidan. Bo'sh bo'lsa — SMS o'chiq (qolgan tizim ishlaydi).
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
# Tasdiqlangan sender nomi yoki test uchun 4546
ESKIZ_FROM=4546
ESKIZ_BASE=https://notify.eskiz.uz/api
