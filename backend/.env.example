# ── Telegram bot ──────────────────────────────────────────────────────────
# @BotFather'dan olingan token. Bo'sh bo'lsa bot ishlamaydi (qolgan qism ishlaydi).
TELEGRAM_BOT_TOKEN=

# ── Server ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Xavfsizlik ────────────────────────────────────────────────────────────
# JWT siri. Bo'sh qoldirsangiz — avtomatik yaratiladi va data/.jwt_secret'da saqlanadi.
# Production'da kuchli, tasodifiy qiymat qo'ying.
JWT_SECRET=
# Token amal qilish muddati (masalan: 12h, 7d)
JWT_EXPIRES=12h

# Ruxsat etilgan frontend manzillari (vergul bilan). '*' — barchasi (faqat ishlab chiqishda).
# Production misol: CORS_ORIGINS=https://sement.example.com,https://www.sement.example.com
CORS_ORIGINS=*
